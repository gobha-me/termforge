# Build trees: anchored to the root, directories only. The old `*build*`
# matched any file with "build" in its name anywhere (e.g.
# docs/building-test.md), silently never committing it.
/build*/
/Testing*/
include/version.hpp

# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# editor
*.swp
*.swo

# screenshots / local artifacts
remmina_*.png
*.png.local
